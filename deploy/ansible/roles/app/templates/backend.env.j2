# Financial Tracker Backend - Production Environment
# Managed by Ansible - Do not edit manually

# Database
DATABASE_URL="postgresql://{{ postgresql.db_user }}:{{ postgresql.db_password }}@localhost:5432/{{ postgresql.db_name }}"

# Server
PORT={{ backend_port }}
HOST=127.0.0.1
NODE_ENV=production

# Logging
LOG_LEVEL=info

# CORS
{% if app_domain | default('') != '' %}
CORS_ORIGIN=https://{{ app_domain }}
{% else %}
CORS_ORIGIN=http://{{ ansible_host }}
{% endif %}

# Authentication
JWT_SECRET={{ jwt_secret }}
JWT_EXPIRES_IN=7d

# Uploads
UPLOAD_DIR={{ app.dir }}/backend/uploads
