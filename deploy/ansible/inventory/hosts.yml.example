# =============================================================================
# Ansible Inventory
# =============================================================================
# Copy this file to hosts.yml and update with your server IP
# Use the same Linode VPS as granny-ledger

all:
  hosts:
    financial-tracker:
      ansible_host: YOUR_SERVER_IP_HERE  # Same server as granny-ledger
      ansible_user: root
      ansible_python_interpreter: /usr/bin/python3
      ansible_ssh_private_key_file: ~/.ssh/id_ed25519
