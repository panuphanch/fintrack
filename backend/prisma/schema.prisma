// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Household {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  users        User[]
  creditCards  CreditCard[]
  transactions Transaction[]
  budgets      Budget[]
  tags         Tag[]
  installments Installment[]
  fixedCosts   FixedCost[]
  categories   Category[]
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  householdId  String
  household    Household @relation(fields: [householdId], references: [id])
  createdAt    DateTime  @default(now())

  ownedCards      CreditCard[]
  transactions    Transaction[] @relation("CreatedBy")
  invitationsSent Invitation[]  @relation("InvitedBy")
  installments    Installment[] @relation("InstallmentCreatedBy")
  fixedCosts      FixedCost[]   @relation("FixedCostCreatedBy")

  @@index([householdId])
}

model Invitation {
  id          String    @id @default(cuid())
  email       String
  token       String    @unique
  householdId String
  invitedById String
  invitedBy   User      @relation("InvitedBy", fields: [invitedById], references: [id])
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([token])
  @@index([email])
}

model CreditCard {
  id          String    @id @default(cuid())
  householdId String
  household   Household @relation(fields: [householdId], references: [id])
  name        String
  bank        String
  lastFour    String
  color       String
  cutoffDay   Int // 1-31
  dueDay      Int // 1-31
  creditLimit Decimal   @db.Decimal(12, 2)
  ownerId     String?
  owner       User?     @relation(fields: [ownerId], references: [id])
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  transactions Transaction[]
  statements   Statement[]
  installments Installment[]

  @@index([householdId])
  @@index([isActive])
}

model Transaction {
  id          String    @id @default(cuid())
  householdId String
  household   Household  @relation(fields: [householdId], references: [id])
  cardId      String
  card        CreditCard @relation(fields: [cardId], references: [id])
  amount      Decimal    @db.Decimal(12, 2)
  merchant    String
  categoryId  String
  category    Category   @relation(fields: [categoryId], references: [id])
  date        DateTime
  notes       String?
  receiptUrl  String?
  isRecurring Boolean    @default(false)
  createdById String
  createdBy   User       @relation("CreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  tags TransactionTag[]

  @@index([householdId])
  @@index([cardId])
  @@index([categoryId])
  @@index([date])
}

model Tag {
  id          String    @id @default(cuid())
  householdId String
  household   Household @relation(fields: [householdId], references: [id])
  name        String

  transactions TransactionTag[]

  @@unique([householdId, name])
  @@index([householdId])
}

model TransactionTag {
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tagId         String
  tag           Tag         @relation(fields: [tagId], references: [id])

  @@id([transactionId, tagId])
}

model Budget {
  id           String    @id @default(cuid())
  householdId  String
  household    Household @relation(fields: [householdId], references: [id])
  categoryId   String
  category     Category  @relation(fields: [categoryId], references: [id])
  monthlyLimit Decimal   @db.Decimal(12, 2)
  createdAt    DateTime  @default(now())

  @@unique([householdId, categoryId])
  @@index([householdId])
}

model Statement {
  id          String     @id @default(cuid())
  cardId      String
  card        CreditCard @relation(fields: [cardId], references: [id])
  periodStart DateTime
  periodEnd   DateTime
  totalAmount Decimal    @db.Decimal(12, 2)
  isPaid      Boolean    @default(false)
  paidAt      DateTime?
  createdAt   DateTime   @default(now())

  @@unique([cardId, periodStart])
  @@index([cardId])
}

// Installment purchases (credit card payments over multiple months)
model Installment {
  id                String      @id @default(cuid())
  householdId       String
  household         Household   @relation(fields: [householdId], references: [id])
  cardId            String?
  card              CreditCard? @relation(fields: [cardId], references: [id])
  name              String
  totalAmount       Decimal     @db.Decimal(12, 2)
  monthlyAmount     Decimal     @db.Decimal(12, 2)
  currentInstallment Int        @default(1)
  totalInstallments Int
  categoryId        String
  category          Category    @relation(fields: [categoryId], references: [id])
  startDate         DateTime    // When the installment started
  notes             String?
  isActive          Boolean     @default(true)
  createdById       String
  createdBy         User        @relation("InstallmentCreatedBy", fields: [createdById], references: [id])
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([householdId])
  @@index([cardId])
  @@index([isActive])
}

// Fixed monthly costs (recurring expenses not tied to credit cards)
model FixedCost {
  id          String    @id @default(cuid())
  householdId String
  household   Household @relation(fields: [householdId], references: [id])
  name        String
  amount      Decimal   @db.Decimal(12, 2)
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id])
  dueDay      Int?      // Day of month when due (1-31)
  isActive    Boolean   @default(true)
  notes       String?
  createdById String
  createdBy   User      @relation("FixedCostCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([householdId])
  @@index([isActive])
}

model Category {
  id          String    @id @default(cuid())
  householdId String
  household   Household @relation(fields: [householdId], references: [id])
  name        String    // e.g., "HOME", "HEALTH"
  label       String    // e.g., "Home", "Health"
  color       String    // e.g., "#3b82f6"
  icon        String?   // e.g., "home", "heart" (icon name)
  sortOrder   Int       @default(0)
  isSystem    Boolean   @default(false) // Prevent deletion of default categories
  parentId    String?   // Parent category for sub-category grouping
  parent      Category? @relation("SubCategories", fields: [parentId], references: [id])
  children    Category[] @relation("SubCategories")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  transactions Transaction[]
  budgets      Budget[]
  installments Installment[]
  fixedCosts   FixedCost[]

  @@unique([householdId, name])
  @@index([householdId])
  @@index([parentId])
}
